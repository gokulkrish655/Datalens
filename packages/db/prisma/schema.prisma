generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum Plan { STARTER PRO ENTERPRISE }
enum TenantRole { BASIC_USER MANAGER DB_ADMIN }
enum UserStatus { PENDING ACTIVE INACTIVE }
enum ConnectionStatus { PENDING CONNECTED ERROR SYNCING PAUSED }
enum ConnectionMethod { DIRECT SSH_TUNNEL }
enum LoadProfile { CONSERVATIVE BALANCED PERFORMANCE }
enum DescriptionSource { AI_GENERATED HUMAN_WRITTEN IMPORTED }
enum TableVisibility { PUBLIC RESTRICTED PRIVATE }
enum SemanticType {
  UNKNOWN
  EMAIL
  PHONE
  FULL_NAME
  FIRST_NAME
  LAST_NAME
  ADDRESS
  URL
  CATEGORY
}
enum RequestStatus { PENDING APPROVED DENIED EXPIRED REVOKED }
enum StageStatus { PENDING APPROVED DENIED SKIPPED }
enum ApproverType { MANAGER TABLE_OWNER DB_ADMIN }
enum MessageRole { USER ASSISTANT }
enum MessageType { QUERY CLARIFICATION_QUESTION CLARIFICATION_ANSWER UNDERSTANDING RESULT BLOCKED ERROR }
enum QueryStatus { SUCCESS BLOCKED_PERMISSION SQL_ERROR LLM_ERROR VALIDATION_ERROR IMPOSSIBLE CLARIFICATION_NEEDED }
enum DownloadFormat { CSV XLSX JSON }
enum ProviderCategory { LLM EMBEDDING EMAIL STORAGE }

model Tenant {
  id                 String           @id @default(uuid())
  name               String
  plan               Plan             @default(STARTER)
  isActive           Boolean          @default(true)
  domains            TenantDomain[]
  users              User[]
  databaseConnections DatabaseConnection[]
  schemaTables       SchemaTable[]
  schemaColumns      SchemaColumn[]
  usageRecords       UsageRecord[]
  providerConfigs    ProviderConfig[]
  accessRequests     AccessRequest[]
  querySessions      QuerySession[]
  impersonationLogs  ImpersonationLog[]
}

model TenantDomain {
  id        String   @id @default(uuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  domain    String   @unique
  createdAt DateTime @default(now())
}

model TenantApiKey {
  id         String   @id @default(uuid())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  tenantId   String
  keyPrefix  String
  keyHash    String
  createdBy  String
  createdAt  DateTime @default(now())
}

model UsageRecord {
  id                   String   @id @default(uuid())
  tenant               Tenant   @relation(fields: [tenantId], references: [id])
  tenantId             String
  month                String
  totalQueries         Int      @default(0)
  fastQueries          Int      @default(0)
  smartQueries         Int      @default(0)
  cacheHits            Int      @default(0)
  estimatedCostUsd     Float    @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  @@index([tenantId, month])
}

model LlmPricingConfig {
  id           String   @id @default(uuid())
  providerName String
  modelId      String
  pricePerToken Float
  effectiveFrom DateTime
  createdAt    DateTime @default(now())
  @@unique([providerName, modelId, effectiveFrom])
}

model User {
  id               String   @id @default(uuid())
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  tenantId         String
  manager          User?    @relation("ManagerReports", fields: [managerId], references: [id])
  reports          User[]   @relation("ManagerReports")
  managerId        String?
  name             String
  email            String   @unique
  role             TenantRole @default(BASIC_USER)
  status           UserStatus @default(PENDING)
  passwordHash     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  sessions         Session[]
  invitations      Invitation[]
  passwordResets   PasswordResetToken[]
  querySessions    QuerySession[]
  createdRequests  AccessRequest[] @relation("Requester")
}

model Session {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  expires   DateTime
  createdAt DateTime @default(now())
}

model Invitation {
  id         String   @id @default(uuid())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  tenantId   String
  email      String
  name       String?
  role       TenantRole @default(BASIC_USER)
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  token      String   @unique
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model DatabaseConnection {
  id                     String   @id @default(uuid())
  tenant                 Tenant   @relation(fields: [tenantId], references: [id])
  tenantId               String
  name                   String
  connectorName          String
  host                   String
  port                   Int?
  database               String?
  schema                 String?
  encryptedCredentials   String
  status                 ConnectionStatus @default(PENDING)
  loadProfile            LoadProfile @default(BALANCED)
  queryRowLimit          Int    @default(50000)
  queryTimeoutSeconds    Int    @default(60)
  cacheTtlSeconds        Int    @default(300)
  dailyQueryCap          Int?   @default(0)
  crawlWindowStart       String?
  crawlWindowEnd         String?
  disclosureAcknowledgedAt DateTime?
  disclosureAcknowledgedBy String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  querySessions          QuerySession[]
}

model SchemaTable {
  id                   String   @id @default(uuid())
  tenant               Tenant   @relation(fields: [tenantId], references: [id])
  tenantId             String
  connection           DatabaseConnection @relation(fields: [connectionId], references: [id])
  connectionId         String
  tableName            String
  displayName          String
  description          String?
  descriptionSource    DescriptionSource
  descriptionApproved  Boolean @default(false)
  rowCountEstimate     BigInt?
  visibility           TableVisibility @default(PUBLIC)
  ownerId              String?
  embedding            Unsupported("vector(1536)")?
  embeddingUpdatedAt   DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  columns              SchemaColumn[]
  @@index([tenantId])
}

model SchemaColumn {
  id                String   @id @default(uuid())
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  tenantId          String
  table             SchemaTable @relation(fields: [tableId], references: [id])
  tableId           String
  columnName        String
  displayName       String
  dataType          String
  semanticType      SemanticType @default(UNKNOWN)
  description       String?
  descriptionSource DescriptionSource
  pii               Boolean @default(false)
  valueDictionary   Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@index([tenantId])
}

model RowFilter {
  id           String   @id @default(uuid())
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  tenantId     String
  table        SchemaTable @relation(fields: [tableId], references: [id])
  tableId      String
  column       String
  value        String
  sqlFragment  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TableOwnership {
  id           String   @id @default(uuid())
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  tenantId     String
  table        SchemaTable @relation(fields: [tableId], references: [id])
  tableId      String
  ownerId      String
  assignedBy   String
  createdAt    DateTime @default(now())
}

model TableAccessGrant {
  id          String   @id @default(uuid())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  tenantId    String
  table       SchemaTable @relation(fields: [tableId], references: [id])
  tableId     String
  grantedTo   User     @relation(fields: [grantedToId], references: [id])
  grantedToId String
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  @@unique([tableId, grantedToId])
}

model AccessRequest {
  id           String   @id @default(uuid())
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  tenantId     String
  table        SchemaTable @relation(fields: [tableId], references: [id])
  tableId      String
  requestedBy  User     @relation("Requester", fields: [requestedById], references: [id])
  requestedById String
  justification String
  durationDays  Int
  status        RequestStatus @default(PENDING)
  stages        AccessRequestStage[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tableId, status])
}

model AccessRequestStage {
  id           String   @id @default(uuid())
  request      AccessRequest @relation(fields: [requestId], references: [id])
  requestId    String
  stageNumber  Int
  status       StageStatus @default(PENDING)
  approverType ApproverType
  assignedToId String?
  note         String?
  isAdminOverride Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([status])
}

model QuerySession {
  id         String   @id @default(uuid())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  tenantId   String
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  title      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  messages   QueryMessage[]
  queryLogs  QueryLog[]
  @@index([tenantId, userId])
}

model QueryMessage {
  id        String       @id @default(uuid())
  session   QuerySession @relation(fields: [sessionId], references: [id])
  sessionId String
  role      MessageRole
  type      MessageType
  content   String
  createdAt DateTime @default(now())
  tables    QueryMessageTable[]
  @@index([sessionId])
}

model QueryMessageTable {
  messageId String
  tableId   String
  join      String?
  @@id([messageId, tableId])
}

model QueryLog {
  id            String   @id @default(uuid())
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  tenantId      String
  session       QuerySession @relation(fields: [sessionId], references: [id])
  sessionId     String
  queryText     String
  status        QueryStatus
  executedSql   String?
  errorMessage  String?
  isImpersonated Boolean @default(false)
  impersonatedBy String?
  createdAt     DateTime @default(now())
  @@index([tenantId, createdAt])
}

model ProviderConfig {
  id            String   @id @default(uuid())
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  tenantId      String
  category      ProviderCategory
  providerName  String
  config        Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@unique([tenantId, category])
}

model ImpersonationLog {
  id             String   @id @default(uuid())
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  tenantId       String
  adminEmail     String
  userId         String
  startedAt      DateTime @default(now())
  endedAt        DateTime?
}

model DeletionAuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  deletedBy  String
  reason     String?
  createdAt  DateTime @default(now())
}
